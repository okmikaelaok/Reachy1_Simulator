{
  "stt_backend": "vosk",
  "model_path": ".local_voice_models/vosk-model-small-en-us-0.15",
  "intent_confidence_threshold": 0.78,
  "transcript_default_confidence": 0.85,
  "transcript_parser_enabled": true,
  "min_transcript_chars": 4,
  "min_transcript_words": 1,
  "safe_numeric_parsing": true,
  "require_target_token_for_joint": false,
  "reject_out_of_range_joint_commands": true,
  "joint_min_degrees": -180.0,
  "joint_max_degrees": 180.0,
  "suppress_duplicate_commands": true,
  "duplicate_command_window_seconds": 1.25,
  "simulation_only_mode": false,
  "tts_feedback_enabled": true,
  "tts_endpoint": "http://127.0.0.1:8099/speak",
  "tts_min_interval_seconds": 0.35,
  "mirror_tts_to_robot_speaker": true,
  "robot_speaker_port": 8101,
  "push_to_talk_enabled": false,
  "push_to_talk_key": "V",
  "listening_enabled": true,
  "listening_endpoint": "http://127.0.0.1:8099/listening",
  "preferred_microphone_device_name": "",
  "ignore_virtual_microphone_devices": true,
  "auto_start_sidecar": true,
  "auto_stop_autostarted_sidecar_on_disable": true,
  "sidecar_sync_config_on_start": true,
  "sidecar_python_command": "python",
  "sidecar_script_relative_path": "ReachyControlApp/LocalVoiceAgent/local_voice_agent_sidecar.py",
  "sidecar_config_relative_path": "ReachyControlApp/LocalVoiceAgent/local_voice_agent_sidecar_config.json",
  "sidecar_log_level": "warning",
  "sidecar_startup_timeout_seconds": 8.0,
  "sidecar_retry_interval_seconds": 2.0,
  "sidecar_health_timeout_ms": 900,
  "heartbeat_timeout_seconds": 4.0,
  "retry_backoff_min_seconds": 0.4,
  "retry_backoff_max_seconds": 4.0,
  "degraded_failure_threshold": 5,
  "block_motion_when_bridge_unhealthy": true,
  "local_help_model_enabled": true,
  "help_endpoint": "http://127.0.0.1:8099/help",
  "help_context": "Reachy Unity app guidance only. Do not generate direct motion execution without explicit intent confirmation.",
  "help_model_backend": "llama_cpp",
  "help_model_path": ".local_voice_models/llm/SmolLM2-360M-Instruct-Q4_K_M.gguf",
  "help_model_max_tokens": 96,
  "help_model_temperature": 0.2,
  "help_max_answer_chars": 360,
  "ipc_endpoint": "http://127.0.0.1:8099/intent"
}
